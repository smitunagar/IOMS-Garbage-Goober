<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0"><%= t('historyTitle') %></h4>

  <!-- Filter pills -->
  <div class="d-flex gap-1">
    <a href="/history?filter=all"
       class="btn btn-sm <%= filter === 'all' ? 'btn-primary' : 'btn-outline-secondary' %>">
      <%= t('filterAll') %>
    </a>
    <a href="/history?filter=disposal"
       class="btn btn-sm <%= filter === 'disposal' ? 'btn-primary' : 'btn-outline-secondary' %>">
      <%= t('disposal') %>
    </a>
    <a href="/history?filter=alert"
       class="btn btn-sm <%= filter === 'alert' ? 'btn-primary' : 'btn-outline-secondary' %>">
      <%= t('alert') %>
    </a>
  </div>
</div>

<% if (entries.length === 0) { %>
  <div class="empty-state">
    <i class="bi bi-inbox"></i>
    <p class="fw-semibold"><%= t('noEntriesYet') %></p>
    <p class="small"><%= t('disposalsAppearHere') %></p>
  </div>
<% } else { %>
  <div class="list-group">
    <% entries.forEach(entry => { %>
      <div class="list-group-item">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <% if (entry.type === 'disposal') { %>
              <span class="badge bg-success me-1"><%= t('disposal') %></span>
              <% entry.binTypes.forEach(bt => { %>
                <span title="<%= BIN_TYPES[bt] ? (BIN_TYPES[bt][lang] || BIN_TYPES[bt].de) : bt %>">
                  <%= BIN_TYPES[bt] ? BIN_TYPES[bt].emoji : '🗑️' %>
                </span>
              <% }); %>
            <% } else { %>
              <span class="badge bg-warning text-dark me-1"><%= t('alert') %></span>
              <span><%= BIN_TYPES[entry.binType] ? BIN_TYPES[entry.binType].emoji : '' %></span>
              <span class="small"><%= t('binReportedFull', { binType: BIN_TYPES[entry.binType] ? (BIN_TYPES[entry.binType][lang] || BIN_TYPES[entry.binType].de) : entry.binType }) %></span>
              <% if (entry.isResolved) { %>
                <span class="badge bg-secondary ms-1"><%= t('resolved') %></span>
              <% } else { %>
                <span class="badge bg-danger ms-1"><%= t('open') %></span>
              <% } %>
            <% } %>
          </div>
          <small class="text-muted"><%= fmtDateTime(new Date(entry.date)) %></small>
        </div>
        <div class="small text-muted mt-1">
          <i class="bi bi-person me-1"></i><%= entry.userName || '–' %>
          <% if (entry.roomId) { %>
            · Room <%= entry.roomId %>
          <% } %>
          <% if (entry.note) { %>
            · <em>"<%= entry.note %>"</em>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>
