<div class="lp-wrap">
  <div class="lp-center">

    <div class="lp-mascot-wrap">
      <img src="/images/Mascot.png" alt="Garbage Goober" class="lp-mascot-img">
    </div>

    <div class="lp-card">

      <div class="lp-logo-wrap">
        <img src="/images/logo-auth.png" alt="Garbage Goober" class="lp-logo-img">
      </div>

      <h2 class="lp-card-sub-heading"><%= t('verifyOtpTitle') %></h2>
      <p class="lp-card-sub"><%= t('verifyOtpBody', { email: email }) %></p>

      <% if (flash && flash.error) { %>
        <div class="alert alert-danger mb-3" role="alert">
          <i class="bi bi-exclamation-circle me-1"></i><%= flash.error %>
        </div>
      <% } %>
      <% if (flash && flash.success) { %>
        <div class="alert alert-success mb-3" role="alert">
          <i class="bi bi-check-circle me-1"></i><%= flash.success %>
        </div>
      <% } %>

      <!-- OTP entry form -->
      <form method="POST" action="/verify-otp">
        <input type="hidden" name="email" value="<%= email %>">

        <div class="mb-4">
          <input type="text"
                 name="otp"
                 id="otpInput"
                 class="form-control text-center fw-bold"
                 style="font-size:2rem;letter-spacing:0.5rem;padding:12px 0;"
                 inputmode="numeric"
                 pattern="[0-9]{6}"
                 maxlength="6"
                 placeholder="——————"
                 autocomplete="one-time-code"
                 required
                 autofocus>
        </div>

        <button type="submit" class="btn btn-login w-100">
          <%= t('verifyOtpButton') %>
          <i class="bi bi-check-lg ms-2"></i>
        </button>
      </form>

      <div class="lp-divider"><span>or</span></div>

      <!-- Resend form -->
      <form method="POST" action="/verify-otp/resend">
        <input type="hidden" name="email" value="<%= email %>">
        <button type="submit" class="btn btn-outline-secondary w-100">
          <i class="bi bi-envelope-arrow-up me-1"></i><%= t('resendVerificationButton') %>
        </button>
      </form>

      <div class="mt-3 text-center">
        <a href="/login" class="text-muted small"><%= t('loginLink') %></a>
      </div>

      <div class="lp-lang-bar">
        <form method="POST" action="/set-language" class="d-flex gap-2" data-no-loader="true">
          <button name="language" value="de" class="btn btn-xs-lang <%= lang === 'de' ? 'active' : '' %>">🇩🇪 DE</button>
          <button name="language" value="en" class="btn btn-xs-lang <%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</button>
        </form>
      </div>

    </div><!-- /.lp-card -->

    <div class="lp-wm-credit">
      <img src="/images/logo2.png" alt="WebMeister360" class="lp-wm-logo">
    </div>

  </div>
</div>
