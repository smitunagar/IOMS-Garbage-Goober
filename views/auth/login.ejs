<div class="lp-wrap">
  <div class="lp-center">

    <!-- mascot floats above card -->
    <div class="lp-mascot-wrap">
      <img src="/images/Mascot.png" alt="Garbage Goober" class="lp-mascot-img">
    </div>

    <!-- main card -->
    <div class="lp-card">

      <!-- logo -->
      <div class="lp-logo-wrap">
        <img src="/images/logo-auth.png" alt="Garbage Goober" class="lp-logo-img">
      </div>

      <% if (flash && flash.error) { %>
        <div class="alert alert-danger mb-3" role="alert">
          <i class="bi bi-exclamation-circle me-1"></i><%= flash.error %>
        </div>
      <% } %>
      <% if (flash && flash.success) { %>
        <div class="alert alert-success mb-3" role="alert">
          <i class="bi bi-check-circle me-1"></i><%= flash.success %>
        </div>
      <% } %>
      <% if (locals.query && locals.query.deleted === '1') { %>
        <div class="alert alert-success mb-3" role="alert">
          <i class="bi bi-check-circle me-1"></i><%= t('deleteAccountSuccessMessage') %>
        </div>
      <% } %>
      <% if (locals.query && locals.query.suspended === '1') { %>
        <div class="alert alert-warning mb-3" role="alert">
          <i class="bi bi-slash-circle me-1"></i><%= t('accountSuspendedMessage') %>
        </div>
      <% } %>

      <form method="POST" action="/login" novalidate>
        <div class="input-float mb-3">
          <input type="email" name="email" id="loginEmail"
                 class="form-control"
                 placeholder=" " required autofocus>
          <label for="loginEmail">
            <i class="bi bi-envelope me-1"></i><%= t('emailLabel') %>
          </label>
        </div>

        <div class="input-float mb-2">
          <input type="password" name="password" id="loginPw"
                 class="form-control"
                 placeholder=" " required>
          <label for="loginPw">
            <i class="bi bi-lock me-1"></i><%= t('passwordLabel') %>
          </label>
        </div>
        <div class="text-end mb-4">
          <a href="/forgot-password" class="text-muted small"><%= t('forgotPasswordLink') %></a>
        </div>

        <button type="submit" class="btn btn-login w-100">
          <%= t('loginButton') %>
          <i class="bi bi-arrow-right ms-2"></i>
        </button>
      </form>

      <div class="lp-divider"><span>or</span></div>

      <p class="text-center text-muted small mb-0">
        <%= t('noAccountYet') %>
        <a href="/signup" class="login-link"><%= t('signUpLink') %></a>
      </p>

      <!-- language toggle footer -->
      <div class="lp-lang-bar">
        <form method="POST" action="/set-language" class="d-flex gap-2">
          <button name="language" value="de" class="btn btn-xs-lang <%= lang === 'de' ? 'active' : '' %>">🇩🇪 DE</button>
          <button name="language" value="en" class="btn btn-xs-lang <%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</button>
        </form>
      </div>

    </div><!-- /.lp-card -->

    <!-- WebMeister360 credit -->
    <div class="lp-wm-credit">
      <img src="/images/logo2.png" alt="WebMeister360" class="lp-wm-logo">
    </div>

  </div><!-- /.lp-center -->
</div><!-- /.lp-wrap -->
