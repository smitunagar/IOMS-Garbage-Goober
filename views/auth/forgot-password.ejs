<div class="lp-wrap">
  <div class="lp-center">

    <div class="lp-mascot-wrap">
      <img src="/images/Mascot.png" alt="Garbage Goober" class="lp-mascot-img">
    </div>

    <div class="lp-card">

      <div class="lp-logo-wrap">
        <img src="/images/logo-auth.png" alt="Garbage Goober" class="lp-logo-img">
      </div>

      <h2 class="lp-card-sub-heading"><%= t('resetPasswordTitle') %></h2>
      <p class="lp-card-sub"><%= t('resetPasswordDescription') %></p>

      <% if (flash && flash.success) { %>
        <div class="alert alert-success mb-3" role="alert">
          <i class="bi bi-check-circle me-1"></i><%= flash.success %>
        </div>
      <% } %>
      <% if (flash && flash.error) { %>
        <div class="alert alert-danger mb-3" role="alert">
          <i class="bi bi-exclamation-circle me-1"></i><%= flash.error %>
        </div>
      <% } %>

      <form method="POST" action="/forgot-password">
        <div class="input-float mb-4">
          <input type="email" name="email" id="forgotEmail"
                 class="form-control" placeholder=" " required autofocus>
          <label for="forgotEmail">
            <i class="bi bi-envelope me-1"></i><%= t('emailLabel') %>
          </label>
        </div>

        <button type="submit" class="btn btn-login w-100">
          <%= t('sendResetLinkButton') %>
          <i class="bi bi-arrow-right ms-2"></i>
        </button>
      </form>

      <div class="lp-divider"><span>or</span></div>

      <p class="text-center text-muted small mb-0">
        <a href="/login" class="login-link"><%= t('loginLink') %></a>
      </p>

      <div class="lp-lang-bar">
        <form method="POST" action="/set-language" class="d-flex gap-2" data-no-loader="true">
          <button name="language" value="de" class="btn btn-xs-lang <%= lang === 'de' ? 'active' : '' %>">🇩🇪 DE</button>
          <button name="language" value="en" class="btn btn-xs-lang <%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</button>
        </form>
      </div>

    </div><!-- /.lp-card -->

    <div class="lp-wm-credit">
      <img src="/images/logo2.png" alt="WebMeister360" class="lp-wm-logo">
    </div>

  </div>
</div>
