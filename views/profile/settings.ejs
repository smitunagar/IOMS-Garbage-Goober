<!-- ── Header ─────────────────────────────────────────────────────────── -->
<div class="d-flex align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-1">
      <i class="bi bi-gear-fill me-2" style="color: var(--primary);"></i>Settings
    </h4>
    <p class="text-muted small mb-0">Manage your profile and notification preferences.</p>
  </div>
</div>

<!-- ── Flash ─────────────────────────────────────────────────────────────── -->
<% if (flash && flash.success) { %>
  <div class="alert alert-success d-flex gap-2 align-items-center py-2 mb-3">
    <i class="bi bi-check-circle-fill flex-shrink-0"></i>
    <span><%= flash.success %></span>
  </div>
<% } %>
<% if (flash && flash.error) { %>
  <div class="alert alert-danger d-flex gap-2 align-items-center py-2 mb-3">
    <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
    <span><%= flash.error %></span>
  </div>
<% } %>

<!-- ── Display Name ───────────────────────────────────────────────────────── -->
<div class="stat-card mb-4">
  <h6 class="fw-semibold mb-3">
    <i class="bi bi-person-fill me-2" style="color: var(--primary);"></i>Display Name
  </h6>
  <form method="POST" action="/profile/name">
    <div class="row g-2 align-items-end">
      <div class="col-12 col-sm-8">
        <label class="form-label small fw-semibold">Name</label>
        <input type="text" name="name" class="form-control"
               value="<%= user.name %>" maxlength="80" required>
      </div>
      <div class="col-12 col-sm-4">
        <button type="submit" class="btn btn-success w-100">
          <i class="bi bi-check-lg me-1"></i>Save Name
        </button>
      </div>
    </div>
  </form>
</div>

<!-- ── WhatsApp Notifications ────────────────────────────────────────────── -->
<div class="stat-card mb-4">
  <div class="d-flex align-items-center gap-2 mb-1">
    <h6 class="fw-semibold mb-0">
      <i class="bi bi-whatsapp me-2" style="color: #25D366;"></i>WhatsApp Notifications
    </h6>
    <% if (user.phone && user.whatsapp_key) { %>
      <span class="badge bg-success ms-1">Active</span>
    <% } else { %>
      <span class="badge bg-secondary ms-1">Not set up</span>
    <% } %>
  </div>
  <p class="text-muted small mb-3">
    When you're on Trash Duty, you'll get a WhatsApp message the moment someone reports a full bin on your floor.
  </p>

  <!-- Setup instructions -->
  <div class="alert alert-info d-flex gap-2 align-items-start py-2 mb-3" style="font-size: 0.82rem;">
    <i class="bi bi-info-circle-fill mt-1 flex-shrink-0" style="color: #0ea5e9;"></i>
    <div>
      <strong>One-time setup (free):</strong>
      <ol class="mb-0 mt-1 ps-3">
        <li>Save <strong>+34 644 64 21 21</strong> as a contact named <em>CallMeBot</em></li>
        <li>Send this exact message to that contact on WhatsApp:<br>
          <code class="user-select-all">I allow callmebot to send me messages</code>
        </li>
        <li>You'll receive your personal <strong>API key</strong> within seconds</li>
        <li>Enter your phone number and API key below</li>
      </ol>
    </div>
  </div>

  <form method="POST" action="/profile/whatsapp">
    <div class="row g-3">
      <div class="col-12 col-sm-6">
        <label class="form-label small fw-semibold">
          <i class="bi bi-telephone-fill me-1"></i>WhatsApp Phone Number
        </label>
        <input type="text" name="phone" class="form-control"
               value="<%= user.phone || '' %>"
               placeholder="+49 176 12345678"
               maxlength="30">
        <div class="form-text">International format with country code (e.g. +49…)</div>
      </div>
      <div class="col-12 col-sm-6">
        <label class="form-label small fw-semibold">
          <i class="bi bi-key-fill me-1"></i>CallMeBot API Key
        </label>
        <input type="text" name="whatsapp_key" class="form-control"
               value="<%= user.whatsapp_key || '' %>"
               placeholder="1234567"
               maxlength="30">
        <div class="form-text">The key CallMeBot sent you on WhatsApp</div>
      </div>
      <div class="col-12 d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-success">
          <i class="bi bi-save-fill me-1"></i>Save WhatsApp Settings
        </button>
        <% if (user.phone && user.whatsapp_key) { %>
        <button type="button" id="testWaBtn" class="btn btn-outline-success">
          <i class="bi bi-send-fill me-1"></i>Send Test Message
        </button>
        <% } %>
      </div>
    </div>
  </form>
</div>

<!-- ── Account Info (read-only) ─────────────────────────────────────────── -->
<div class="stat-card mb-4">
  <h6 class="fw-semibold mb-3">
    <i class="bi bi-info-circle-fill me-2" style="color: var(--primary);"></i>Account Info
  </h6>
  <div class="row g-2 text-muted small">
    <div class="col-6 col-sm-3 fw-semibold text-dark">Email</div>
    <div class="col-6 col-sm-9"><%= user.email %></div>
    <div class="col-6 col-sm-3 fw-semibold text-dark">Room</div>
    <div class="col-6 col-sm-9"><%= C.roomLabel(user.room_id) %></div>
    <div class="col-6 col-sm-3 fw-semibold text-dark">Floor</div>
    <div class="col-6 col-sm-9">Floor <%= user.floor_id %></div>
    <div class="col-6 col-sm-3 fw-semibold text-dark">Role</div>
    <div class="col-6 col-sm-9 text-capitalize"><%= user.role || 'student' %></div>
  </div>
</div>

<!-- ── Test WA hidden form ────────────────────────────────────────────────── -->
<form id="testWaForm" method="POST" action="/profile/whatsapp/test" class="d-none"></form>

<script>
  const testBtn = document.getElementById('testWaBtn');
  if (testBtn) {
    testBtn.addEventListener('click', () => {
      testBtn.disabled = true;
      testBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending…';
      document.getElementById('testWaForm').submit();
    });
  }
</script>
