<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#2E7D32">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Garbage Goober">
  <meta name="description" content="Smart waste disposal management for GWG Reutlingen residents.">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' – ' : '' %>Garbage Goober</title>
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192x192.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<!-- ── Page-transition progress bar (starts before DOMContentLoaded) ──────── -->
<div id="gg-pb" aria-hidden="true"></div>
<script>
  // Start bar immediately as HTML begins parsing – gives instant visual feedback
  // even before any JS bundle has loaded.
  (function(){
    var b = document.getElementById('gg-pb');
    if (b) b.classList.add('gg-pb-run');
  })();
</script>

<% if (user && user.is_onboarded) { %>
  <!-- ── Mobile top navbar ─────────────────────────────────────────────── -->
  <nav class="navbar mobile-nav d-lg-none sticky-top">
    <div class="container-fluid">
      <button class="btn text-white p-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMobile">
        <i class="bi bi-list fs-3"></i>
      </button>
      <span></span>
      <span></span>
    </div>
  </nav>

  <!-- ── Mobile offcanvas sidebar ──────────────────────────────────────── -->
  <div class="offcanvas offcanvas-start d-lg-none" id="sidebarMobile" tabindex="-1"
       style="background: linear-gradient(180deg, #1B4D1F 0%, #2E7D32 60%, #255C28 100%); width: 260px;">
    <div class="offcanvas-header" style="border-bottom: 1px solid rgba(255,255,255,0.10); padding-top: max(1rem, env(safe-area-inset-top));">
      <span></span>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-0" style="overflow-y: auto; padding-bottom: env(safe-area-inset-bottom) !important;">
      <%- include('partials/sidebar') %>
    </div>
  </div>

  <!-- ── Desktop layout ────────────────────────────────────────────────── -->
  <div class="d-flex">
    <aside class="sidebar d-none d-lg-flex flex-column flex-shrink-0">
      <%- include('partials/sidebar') %>
    </aside>
    <main class="flex-grow-1 main-content">
      <!-- Flash messages -->
      <% if (flash && flash.success) { %>
        <div class="alert alert-success alert-dismissible fade show" data-auto-dismiss role="alert">
          <%= flash.success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (flash && flash.error) { %>
        <div class="alert alert-danger alert-dismissible fade show" data-auto-dismiss role="alert">
          <%= flash.error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <%- body %>
    </main>
  </div>

<% } else { %>
  <!-- ── Auth / onboarding (no sidebar) ────────────────────────────────── -->
  <%- body %>
<% } %>

<% if (user) { %>
<!-- ── Delete Account Modal (rendered once at body level) ────────────────── -->
<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title text-danger fw-bold" id="deleteAccountModalLabel">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= t('deleteAccountTitle') %>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small mb-3"><%= t('deleteAccountWarning') %></p>
        <form method="POST" action="/account/delete" id="deleteAccountForm">
          <label class="form-label fw-semibold"><%= t('deleteAccountPasswordLabel') %></label>
          <input type="password" name="password" class="form-control mb-1"
                 placeholder="<%= t('passwordRequired') %>" required autocomplete="current-password">
          <div class="form-text text-danger"><%= t('deleteAccountIrreversible') %></div>
        </form>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
          <%= t('cancelButton') %>
        </button>
        <button type="submit" form="deleteAccountForm" class="btn btn-danger btn-sm">
          <i class="bi bi-trash3-fill me-1"></i><%= t('deleteAccountConfirmButton') %>
        </button>
      </div>
    </div>
  </div>
</div>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    });
  }
</script>
<script src="/js/app.js"></script>
<%- include('partials/waste_scanner') %>
<script src="/js/waste-scanner.js"></script>
</body>
</html>
