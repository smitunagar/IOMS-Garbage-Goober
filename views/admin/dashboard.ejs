<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-1"><%= t('adminDashboardTitle') %></h4>
    <p class="text-muted small mb-0"><%= weekLabel %></p>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin/users" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-people-fill me-1"></i> <%= t('adminManageUsersButton') %>
    </a>
    <a href="/admin/compliance" class="btn btn-outline-primary btn-sm">
      <i class="bi bi-bar-chart me-1"></i> <%= t('complianceButton') %>
    </a>
  </div>
</div>

<!-- ── User stats row ─────────────────────────────────────────────────────── -->
<% if (userStats) { %>
<div class="row g-2 mb-4">
  <div class="col-6 col-md-3">
    <div class="stat-card text-center py-3">
      <div class="fs-3 fw-bold" style="color:#2E7D32"><%= userStats.total %></div>
      <div class="text-muted small"><i class="bi bi-people me-1"></i><%= t('adminStatTotalUsers') %></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card text-center py-3">
      <div class="fs-3 fw-bold text-primary"><%= userStats.students %></div>
      <div class="text-muted small"><i class="bi bi-person me-1"></i><%= t('adminStatStudents') %></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card text-center py-3">
      <div class="fs-3 fw-bold text-warning"><%= userStats.floor_speakers %></div>
      <div class="text-muted small"><i class="bi bi-person-badge me-1"></i><%= t('adminStatFloorSpeakers') %></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card text-center py-3">
      <div class="fs-3 fw-bold text-danger"><%= userStats.suspended %></div>
      <div class="text-muted small"><i class="bi bi-person-slash me-1"></i><%= t('adminStatSuspended') %></div>
    </div>
  </div>
</div>
<% } %>

<!-- ── Floor cards ────────────────────────────────────────────────────────── -->
<h6 class="fw-semibold mb-3 text-muted text-uppercase" style="font-size:0.75rem;letter-spacing:.05em">
  <i class="bi bi-building me-1"></i><%= t('adminFloorsHeading') %>
</h6>
<div class="row g-3">
  <% floors.forEach(floor => { %>
  <div class="col-12 col-sm-6 col-lg-4">
    <div class="card floor-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h6 class="fw-bold mb-0"><%= t('floorChipLabel', { floor: floor.id }) %></h6>
          <% if (floor.alertCount > 0) { %>
            <span class="badge bg-danger"><%= floor.alertCount %> <i class="bi bi-exclamation-triangle"></i></span>
          <% } %>
        </div>

        <% if (floor.dutyRoom) { %>
          <p class="mb-1 text-primary-custom fw-semibold">
            <i class="bi bi-person-badge me-1"></i>
            <%= t('assignedRoom', { room: floor.dutyRoom }) %>
          </p>
        <% } else { %>
          <p class="mb-1 text-muted small"><%= t('noDutyAssigned') %></p>
        <% } %>

        <% if (floor.disposalCount > 0) { %>
          <p class="small text-muted mb-2">
            <i class="bi bi-check-circle text-success me-1"></i>
            <%= t('disposalCountThisWeek', { count: floor.disposalCount }) %>
          </p>
        <% } else { %>
          <p class="small text-danger mb-2">
            <i class="bi bi-x-circle me-1"></i>
            <%= t('noDisposalThisWeek') %>
          </p>
        <% } %>

        <a href="/admin/rotation/<%= floor.id %>" class="btn btn-sm btn-outline-primary w-100">
          <i class="bi bi-arrow-repeat me-1"></i> <%= t('rotationButton') %>
        </a>
      </div>
    </div>
  </div>
  <% }); %>
</div>
