<div class="d-flex flex-column h-100 p-3">
  <!-- ── Brand ─────────────────────────────────────────────────────────── -->
  <div class="sidebar-logo-wrap mb-3 px-1">
    <img src="/images/logo.png" alt="Garbage Goober" class="sidebar-logo">
    <p class="sidebar-logo-sub">by iOMS</p>
  </div>

  <!-- ── User info ─────────────────────────────────────────────────────── -->
  <% if (user) { %>
  <div class="px-2 mb-3 small text-muted">
    <div class="fw-semibold text-dark"><%= user.name %></div>
    <div><%= t('roomFloorInfo', { roomId: C.roomLabel(user.room_id), floorId: user.floor_id }) %></div>
  </div>
  <% } %>

  <hr class="mt-0">

  <!-- ── Navigation ────────────────────────────────────────────────────── -->
  <nav class="nav flex-column flex-grow-1">
    <a class="nav-link rounded-2 px-3 py-2 mb-1 <%= path === '/home' ? 'active' : '' %>"
       href="/home">
      <i class="bi bi-house me-2"></i><%= t('navDashboard') %>
    </a>
    <a class="nav-link rounded-2 px-3 py-2 mb-1 <%= path.startsWith('/disposal') ? 'active' : '' %>"
       href="/disposal/log">
      <i class="bi bi-trash me-2"></i><%= t('navDisposal') %>
    </a>
    <a class="nav-link rounded-2 px-3 py-2 mb-1 <%= path.startsWith('/alerts') ? 'active' : '' %>"
       href="/alerts/report">
      <i class="bi bi-exclamation-triangle me-2"></i><%= t('navAlert') %>
    </a>
    <a class="nav-link rounded-2 px-3 py-2 mb-1 <%= path.startsWith('/history') ? 'active' : '' %>"
       href="/history">
      <i class="bi bi-clock-history me-2"></i><%= t('navHistory') %>
    </a>

    <% if (user && user.is_admin) { %>
    <hr>
    <a class="nav-link rounded-2 px-3 py-2 mb-1 <%= path.startsWith('/admin') ? 'active' : '' %>"
       href="/admin">
      <i class="bi bi-shield-lock me-2"></i><%= t('navAdmin') %>
    </a>
    <% } %>
  </nav>

  <!-- ── Bottom section ────────────────────────────────────────────────── -->
  <div class="border-top pt-3 mt-3">
    <!-- Language toggle -->
    <div class="lang-toggle d-flex mb-3 px-2">
      <form method="POST" action="/set-language" class="d-flex gap-1 w-100">
        <button name="language" value="de" class="btn btn-sm flex-fill <%= lang === 'de' ? 'active' : 'btn-outline-secondary' %>">🇩🇪 DE</button>
        <button name="language" value="en" class="btn btn-sm flex-fill <%= lang === 'en' ? 'active' : 'btn-outline-secondary' %>">🇬🇧 EN</button>
      </form>
    </div>

    <a class="nav-link text-danger rounded-2 px-3 py-2" href="/logout">
      <i class="bi bi-box-arrow-left me-2"></i><%= t('logoutButton') %>
    </a>
  </div>
</div>
