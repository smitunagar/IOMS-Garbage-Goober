<div class="sidebar-inner d-flex flex-column h-100">

  <!-- ── Brand header ───────────────────────────────────────────────────── -->
  <div class="sidebar-brand">
    <div class="sidebar-brand-mascot">
      <img src="/images/Mascot.png" alt="Mascot">
    </div>
    <img src="/images/logo.png" alt="Garbage Goober" class="sidebar-brand-logo">
  </div>

  <!-- ── User pill ──────────────────────────────────────────────────────── -->
  <% if (user) { %>
  <div class="sidebar-user">
    <div class="sidebar-user-avatar">
      <%= user.name.charAt(0).toUpperCase() %>
    </div>
    <div class="sidebar-user-info">
      <div class="sidebar-user-name"><%= user.name %></div>
      <div class="sidebar-user-room">
        <% if (user.role === 'floor_speaker') { %>
          <i class="bi bi-person-badge me-1"></i><%= t('floorSpeakerLabel', { floor: user.managed_floor_id }) %>
        <% } else { %>
          <i class="bi bi-door-open me-1"></i><%= C.roomLabel(user.room_id) %>
          &nbsp;·&nbsp;
          <i class="bi bi-building me-1"></i><%= t('floorChipLabel', { floor: user.floor_id }) %>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ── Navigation ─────────────────────────────────────────────────────── -->
  <nav class="sidebar-nav flex-grow-1">
    <a class="sidebar-link <%= path === '/home' ? 'active' : '' %>" href="/home">
      <span class="sidebar-link-icon"><i class="bi bi-house-fill"></i></span>
      <span class="sidebar-link-label"><%= t('navDashboard') %></span>
    </a>
    <a class="sidebar-link <%= path === '/disposal/log' ? 'active' : '' %>" href="/disposal/log">
      <span class="sidebar-link-icon"><i class="bi bi-trash3-fill"></i></span>
      <span class="sidebar-link-label"><%= t('navDisposal') %></span>
    </a>
    <a class="sidebar-link <%= path === '/disposal/feed' ? 'active' : '' %>" href="/disposal/feed">
      <span class="sidebar-link-icon"><i class="bi bi-camera-fill"></i></span>
      <span class="sidebar-link-label"><%= lang === 'de' ? 'Entsorgungsprotokoll' : 'Disposal Feed' %></span>
    </a>
    <a class="sidebar-link <%= path.startsWith('/alerts') ? 'active' : '' %>" href="/alerts/report">
      <span class="sidebar-link-icon"><i class="bi bi-exclamation-triangle-fill"></i></span>
      <span class="sidebar-link-label"><%= t('navAlert') %></span>
    </a>
    <a class="sidebar-link <%= path.startsWith('/history') ? 'active' : '' %>" href="/history">
      <span class="sidebar-link-icon"><i class="bi bi-clock-history"></i></span>
      <span class="sidebar-link-label"><%= t('navHistory') %></span>
    </a>

    <% if (user && user.is_admin) { %>
    <div class="sidebar-section-label">Admin</div>
    <a class="sidebar-link <%= path.startsWith('/admin') ? 'active' : '' %>" href="/admin">
      <span class="sidebar-link-icon"><i class="bi bi-shield-fill-check"></i></span>
      <span class="sidebar-link-label"><%= t('navAdmin') %></span>
    </a>
    <% } %>

    <% if (user && user.role === 'floor_speaker') { %>
    <div class="sidebar-section-label"><%= t('navFloorSpeakerSection') %></div>
    <a class="sidebar-link <%= path.startsWith('/floor-speaker') ? 'active' : '' %>" href="/floor-speaker/rotation/<%= user.managed_floor_id %>">
      <span class="sidebar-link-icon"><i class="bi bi-people-fill"></i></span>
      <span class="sidebar-link-label"><%= t('navFloorSpeaker') %></span>
    </a>
    <% } %>
  </nav>

  <!-- ── Footer ─────────────────────────────────────────────────────────── -->
  <div class="sidebar-footer">
    <form method="POST" action="/set-language" class="sidebar-lang">
      <button name="language" value="de"
              class="sidebar-lang-btn <%= lang === 'de' ? 'active' : '' %>">🇩🇪 DE</button>
      <button name="language" value="en"
              class="sidebar-lang-btn <%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</button>
    </form>
    <a class="sidebar-logout" href="/logout">
      <i class="bi bi-box-arrow-left me-2"></i><%= t('logoutButton') %>
    </a>
  </div>

</div>
