<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#2E7D32">
  <title>Offline – Garbage Goober</title>
  <link rel="manifest" href="/manifest.json">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: linear-gradient(160deg, #1B4D1F 0%, #2E7D32 100%);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #fff;
      padding: 2rem;
      text-align: center;
    }
    .icon { font-size: 4rem; margin-bottom: 1.25rem; opacity: 0.9; }
    h1 { font-size: 1.6rem; font-weight: 800; margin-bottom: 0.5rem; }
    p  { font-size: 0.95rem; opacity: 0.80; line-height: 1.5; max-width: 300px; }
    .btn {
      margin-top: 2rem;
      padding: 0.7rem 2rem;
      background: rgba(255,255,255,0.15);
      border: 2px solid rgba(255,255,255,0.4);
      border-radius: 30px;
      color: #fff;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn:hover { background: rgba(255,255,255,0.28); }
  </style>
</head>
<body>
  <div class="icon">🗑️</div>
  <h1>You're offline</h1>
  <p>No internet connection. Please check your network and try again.</p>
  <a class="btn" href="/" onclick="window.location.reload(); return false;">Try again</a>
</body>
</html>
