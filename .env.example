# ── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get this from https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Session ──────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-long-random-secret

# ── AI Waste Scanner (Google Gemini) ─────────────────────────────────────────
# Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
