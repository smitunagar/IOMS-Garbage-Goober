# ── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get this from https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Session ──────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-long-random-secret

# ── AI Waste Scanner (Google Gemini) ─────────────────────────────────────────
# Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Email Notifications (Nodemailer / SMTP) ──────────────────────────────────
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → generate App Password
# Any SMTP provider works (Outlook, Brevo, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-app@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Garbage Goober" <your-app@gmail.com>
# ── App public URL (used in email links) ─────────────────────────────────────────
# The full public URL of your deployment (no trailing slash)
APP_URL=https://ioms-garbage-goober.vercel.app
# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
