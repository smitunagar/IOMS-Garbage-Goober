{
  "name": "ioms-individual-web",
  "version": "1.0.0",
  "description": "IOMS Individual – Trash duty management web app for GWG Reutlingen student dormitory",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "TZ=UTC jest",
    "test:unit": "TZ=UTC jest --testPathPatterns=tests/unit",
    "test:integration": "TZ=UTC jest --testPathPatterns=tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:load:smoke": "k6 run tests/load/smoke.js",
    "test:load:login": "k6 run tests/load/login.js",
    "test:load:disposal": "k6 run tests/load/disposal.js",
    "test:seed": "node tests/helpers/seed.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
